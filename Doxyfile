#---------------------------------------------------------------------------
# Doxyfile — конфигурация Doxygen для проекта TaMP
# Запуск: doxygen Doxyfile  (из корня репозитория)
# Результат: docs/html/index.html
#---------------------------------------------------------------------------

#---------------------------------------------------------------------------
# Идентификация проекта
#---------------------------------------------------------------------------
PROJECT_NAME           = "TaMP"
PROJECT_BRIEF          = "Task and Math Platform — клиент-серверное приложение на Qt/C++"
PROJECT_NUMBER         = 1.0
OUTPUT_DIRECTORY       = docs

#---------------------------------------------------------------------------
# Входные данные
#---------------------------------------------------------------------------
INPUT                  = TaMP_Client \
                         TaMP_Server \
                         mainpage.dox
INPUT_ENCODING         = UTF-8
FILE_PATTERNS          = *.h *.cpp *.dox
RECURSIVE              = YES

# Исключить сторонние файлы
EXCLUDE_PATTERNS       = */build/* \
                         */cmake-build-debug/* \
                         */qcustomplot.h \
                         */qcustomplot.cpp \
                         */md5_util.h

#---------------------------------------------------------------------------
# Язык и кодировка
#---------------------------------------------------------------------------
OUTPUT_LANGUAGE        = Russian
DOXYFILE_ENCODING      = UTF-8

#---------------------------------------------------------------------------
# Извлечение документации
#---------------------------------------------------------------------------
EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_METHODS  = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
JAVADOC_AUTOBRIEF      = NO

#---------------------------------------------------------------------------
# Предупреждения
#---------------------------------------------------------------------------
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = YES

#---------------------------------------------------------------------------
# HTML-вывод
#---------------------------------------------------------------------------
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_COLORSTYLE        = DARK
GENERATE_TREEVIEW      = YES
TREEVIEW_WIDTH         = 250
HTML_DYNAMIC_SECTIONS  = YES

#---------------------------------------------------------------------------
# LaTeX-вывод (отключён)
#---------------------------------------------------------------------------
GENERATE_LATEX         = NO

#---------------------------------------------------------------------------
# Диаграммы
#---------------------------------------------------------------------------
HAVE_DOT               = NO
CLASS_DIAGRAMS         = YES

#---------------------------------------------------------------------------
# Исходный код в документации
#---------------------------------------------------------------------------
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

#---------------------------------------------------------------------------
# Индексы и поиск
#---------------------------------------------------------------------------
ALPHABETICAL_INDEX     = YES
GENERATE_SEARCHENGINE  = YES

#---------------------------------------------------------------------------
# Подавить вывод Qt-макросов
#---------------------------------------------------------------------------
PREDEFINED             = Q_OBJECT \
                         Q_SIGNALS= \
                         Q_SLOTS= \
                         signals= \
                         slots= \
                         emit=
